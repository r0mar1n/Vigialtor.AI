{
  "manifest_version": 3,
  "name": "Vigilator.AI",
  "version": "1.0",
  "description": "Phishing detection extension.",
  "permissions": [
    "tabs",
    "webNavigation",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/logo.png",
      "48": "icons/logo.png",
      "128": "icons/logo.png"
    },
    "default_title": "Vigilator.AI"
  },
  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  }
}
